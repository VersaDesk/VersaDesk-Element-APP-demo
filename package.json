{
  "name": "element-app-hello-world",
  "version": "0.0.7",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "clean": "rimraf dist",
    "build:ng": "ng build -c production",
    "build:bundle": "concat-glob-cli -f dist/**/*.js -o dist/element-app-hello-world.js",
    "build:copy": "copyfiles -u 1 src/assets/* dist && copyfiles package.json ./dist && rimraf dist/element-app-hello-world",
    "build:zip": "cd ./dist && bestzip ../element-app-hello-world.zip ./*",
    "build": "npm run clean && npm run build:ng && npm run build:bundle && npm run build:copy && npm run build:zip"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.3.18",
    "@angular/animations": "^20.3.17",
    "@angular/cli": "^20.3.18",
    "@angular/common": "^20.3.17",
    "@angular/compiler": "^20.3.17",
    "@angular/compiler-cli": "^20.3.17",
    "@angular/core": "^20.3.17",
    "@angular/elements": "^20.3.17",
    "@angular/forms": "^20.3.17",
    "@angular/platform-browser": "^20.3.17",
    "@angular/platform-browser-dynamic": "^20.3.17",
    "@angular/router": "^20.3.17",
    "@types/jasmine": "~5.1.0",
    "bestzip": "^2.2.1",
    "concat-glob-cli": "^0.1.0",
    "copyfiles": "^2.4.1",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "rimraf": "^5.0.10",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "typescript": "~5.8.3"
  },
  "phantom-desk": {
    "name": "Element App Hello World",
    "type": "element",
    "author": "Evan Lin",
    "email": "evanlin@besta.com.tw",
    "description": "This is an example app",
    "element": "element-app-hello-world.js",
    "icon": "assets/favicon.ico",
    "tagName": "element-app-hello-world",
    "isModule": true,
    "scopes": [
      "project.read",
      "mongo.bdp-elem-example",
      "state",
      "sync",
      "custom-message"
    ]
  }
}
